DATABASE_URL=postgresql+asyncpg://postgres@localhost:5432/order_supervisor
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=order-supervisor-task-queue

# Which provider the classifier / embeddings default to: "openai" or "google".
DEFAULT_PROVIDER=openai

# OpenAI (used when DEFAULT_PROVIDER=openai or a supervisor pins provider=openai)
OPENAI_API_KEY=
DEFAULT_OPENAI_MODEL=gpt-4o-mini

# Google Gemini (used when DEFAULT_PROVIDER=google or a supervisor pins provider=google)
GEMINI_API_KEY=
DEFAULT_GEMINI_MODEL=gemini-2.0-flash
